# Copia este archivo como .env y rellena los valores reales
# NUNCA commitees el .env real a git

# ── Obligatorio ──────────────────────────────────────────────────────────

# API key de Google Gemini (Gemini 2.5 Flash)
# Consíguela en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy_REEMPLAZA_CON_TU_KEY

# ── Opcionales (tienen default) ────────────────────────────────────────────

# Base de datos SQLite (se crea sola al arrancar)
DATABASE_URL=sqlite:///./geo_copilot.db

# Orígenes CORS permitidos (frontend Next.js)
# Varios orígenes separados por coma:
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGINS=http://localhost:3000

# ── WordPress REST (opcional — sin esto, approve usa mock) ─────────────────

# URL base del sitio WP (sin barra final)
# WORDPRESS_URL=https://bancoserfinanzas.kesug.com/wp
WORDPRESS_URL=

# Usuario WP con permiso de editor/admin
WORDPRESS_USERNAME=

# Application Password (WP → Usuarios → Perfil → Contraseñas de aplicación)
WORDPRESS_APP_PASSWORD=

# draft = borrador | publish = visible al público
WORDPRESS_POST_STATUS=draft

# Post donde actualizar meta/excerpt (opcional)
# WORDPRESS_META_POST_ID=1

# Imagen en medios para ALT_TEXT_FIX (opcional)
# WORDPRESS_DEFAULT_MEDIA_ID=1
